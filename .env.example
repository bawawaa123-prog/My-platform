# App
APP_NAME=enterprise-support-agent
APP_ENV=development
SECRET_KEY=replace-with-a-local-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Database
# Default development database is SQLite (no server needed).
DATABASE_URL=sqlite:///./backend/app.db
# Optional MySQL:
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/enterprise_support_agent?charset=utf8mb4
# Optional PostgreSQL DATABASE_URL for Docker Compose profile:
# DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/enterprise_support_agent

# Knowledge
KNOWLEDGE_UPLOAD_DIR=uploads/knowledge

# LLM
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=30

# Embedding
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-embedding-v1
EMBEDDING_DIMENSION=64
VECTOR_STORE_PATH=data/knowledge_vector_store.json

# Frontend
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8010

# Optional PostgreSQL service
POSTGRES_DB=enterprise_support_agent
POSTGRES_USER=app
POSTGRES_PASSWORD=app
